# ============================================================================
# Firmware (large binaries)
# ============================================================================
# Keep tracked: APP.bin, BOOT.bin, UI-QVGA.bin, etc.
# Ignore: SD card images (too large)
firmware/sdcard.img
firmware/*.work.img
firmware/*.img.xz

# ============================================================================
# Ghidra Projects
# ============================================================================
# Keep: .gpr project files
# Ignore: Large repository data
ghidra_projects/**/*.rep/
ghidra_projects/**/*.lock
ghidra_projects/**/*.log

# ============================================================================
# Research & Findings
# ============================================================================
# RE-KB temporary files
research/findings/.re_kb/.id_lock
research/findings/.re_kb.backup.*
research/findings/.re_kb.zip

# Session backups (from anonymization)
research/sessions/.backup_*/
research/sessions/PRIVACY_SCAN_REPORT.md
research/sessions/ANONYMIZATION_COMPLETE.md

# Analysis outputs (large/generated)
research/analysis/*.tmp
research/analysis/temp_*

# ============================================================================
# Vendor Documentation (GITIGNORED - too large)
# ============================================================================
vendor/

# ============================================================================
# Tools & Scripts
# ============================================================================
tools/legacy/*.bak
tools/**/*.tmp

# ============================================================================
# Temporary & Generated Files
# ============================================================================
SENSITIVE_DATA_SCAN_REPORT.md
*.tmp
*.bak
*.log
*.cache
.cache/

